# FastAPI runtime
PORT=8000
UVICORN_RELOAD=true

# Audiveris binary path. Keep as 'audiveris' if in PATH.
AUDIVERIS_BIN=audiveris

# Comma-separated origins (use * for MVP local dev)
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:8000

# Where generated MusicXML downloads are stored
DOWNLOAD_DIR=backend/app/downloads

# Auto-delete download files older than this many seconds
DOWNLOAD_TTL_SECONDS=3600
